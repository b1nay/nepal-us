{
  "manifest_version": 3,
  "name": "Dyslexia Force Mode",
  "version": "3.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.facebook.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}